datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   Int           @id @default(autoincrement())
  doctorName           String
  designation          String
  highestQualification String?
  specialty            String
  hospitalName         String
  pmdcNumber           String        @unique
  city                 String
  phoneNumber          String
  email                String        @unique
  password             String
  profilePicture       String?
  isApproved           Boolean       @default(false)
  isActive             Boolean       @default(true)
  role                 String        @default("user") // "user" or "admin"
  permissions          String[]      @default([]) // For subadmin specific access
  totalPoints    Int           @default(0)
  gamesPlayed    Int           @default(0)
  correctAnswers Int           @default(0)
  wrongAnswers   Int           @default(0)
  lastLogin      DateTime?
  level          Int           @default(1)
  badges         String[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  quizSessions   QuizSession[]
  pinsCreated    Pin[]
  notifications  Notification[]
  conversations1 Conversation[] @relation("ConversationUser1")
  conversations2 Conversation[] @relation("ConversationUser2")
  sentMessages   Message[]
  competitionEnrollments CompetitionEnrollment[]
  roomsCreated   Room[]
  comments       Comment[]
  feedbacks      Feedback[]
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  description   String?
  imageUrl      String?
  isActive      Boolean       @default(true)
  questionCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  questions     Question[]
  quizSessions  QuizSession[]
  pins          Pin[]
  monthlyCompetitions MonthlyCompetition[]
}

model Question {
  id            Int           @id @default(autoincrement())
  question      String
  options       String[]
  correctAnswer Int
  explanation   String?
  imageUrl      String?
  categoryId    Int
  category      Category      @relation(fields: [categoryId], references: [id])
  difficulty    String        @default("medium") // "easy", "medium", "hard"
  isActive      Boolean       @default(true)
  timesAnswered Int           @default(0)
  correctCount  Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessionQuestions QuizSessionQuestion[]
}

model QuizSession {
  id             Int                   @id @default(autoincrement())
  userId         Int
  user           User                  @relation(fields: [userId], references: [id])
  categoryId     Int
  category       Category              @relation(fields: [categoryId], references: [id])
  score          Int                   @default(0)
  totalQuestions Int
  correctAnswers Int                   @default(0)
  wrongAnswers   Int                   @default(0)
  timeSpent      Int                   @default(0)
  gameMode       String                // "single", "multiplayer", "pin"
  roomId         String?
  pin            String?               // For PIN based quizzes
  isCompleted    Boolean               @default(false)
  completedAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  questions      QuizSessionQuestion[]
}

model QuizSessionQuestion {
  id            Int         @id @default(autoincrement())
  quizSessionId Int
  quizSession   QuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  questionId    Int?
  question      Question?   @relation(fields: [questionId], references: [id], onDelete: SetNull)
  userAnswer    Int?
  isCorrect     Boolean?
  timeSpent     Int?
}

model Pin {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  wardName    String
  city        String
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  questionIds Int[]
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  specialty String   @default("All") // "All" or specific specialty
  location  String   @default("dashboard_middle") // "dashboard_middle", "dashboard_footer", "sidebar", "profile_footer"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudyGuide {
  id        Int      @id @default(autoincrement())
  title     String
  pdfUrl    String
  specialty String   @default("All")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id          Int      @id @default(autoincrement())
  title       String
  message     String
  imageUrl    String?
  targetType  String   // "all", "specialty", "city", "hospital", "role"
  targetValue String?  // e.g. "Cardiology", "Karachi", etc.
  isReadBy    Int[]    @default([])
  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Conversation {
  id        Int       @id @default(autoincrement())
  user1Id   Int
  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2Id   Int
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([user1Id, user2Id])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Winner {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  month     String
  year      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyCompetition {
  id              Int                     @id @default(autoincrement())
  name            String
  targetSpecialty String
  posterUrl       String
  date            String
  startTime       String
  endTime         String
  categoryId      Int
  category        Category                @relation(fields: [categoryId], references: [id])
  isActive        Boolean                 @default(true)
  enrollments     CompetitionEnrollment[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model CompetitionEnrollment {
  id            Int                @id @default(autoincrement())
  userId        Int
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitionId Int
  competition   MonthlyCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  score         Int?
  timeSpent     Int?
  completedAt   DateTime?
  enrolledAt    DateTime           @default(now())

  @@unique([userId, competitionId])
}

model Room {
  id           Int      @id @default(autoincrement())
  name         String
  specialty    String
  city         String
  hospitalName String
  pin          String   @unique
  isOpen       Boolean  @default(true)
  creatorId    Int
  creator      User     @relation(fields: [creatorId], references: [id])
  difficulty   String   @default("medium")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Complaint {
  id           Int      @id @default(autoincrement())
  doctorName   String
  specialty    String?
  hospitalName String?
  city         String
  email        String
  phoneNumber  String
  complaint    String
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Comment {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType  String   // "quiz" or "material"
  targetId    Int      // categoryId or studyGuideId
  targetName  String
  content     String
  status      String   @default("Pending") // "Pending", "Approved", "Declined"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feedback {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String
  status      String   @default("Pending") // "Pending", "Approved", "Declined"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

